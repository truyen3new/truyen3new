{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "backend-d1-saas",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "CF_ACCOUNT_ID": "<cloudflare-account-id>",
    "TENANT_DATABASE_PREFIX": "tenant",
    "ADMIN_API_KEY": "test-admin-key-12345",
    "ENABLE_LOCAL_DEV_FALLBACK": "true"
  },
  "d1_databases": [
    {
      "binding": "CONTROL_DB",
      "database_name": "saas-control-plane",
      "database_id": "a531a426-efe9-4655-a1e0-85a54955d9f0"
    }
  ]
}
