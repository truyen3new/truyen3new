+/**
+ * User Engagement Card Component
+ * Displays engagement metrics (DAU, WAU, MAU, churn, etc.)
+ */
+
+'use client';
+
+import React from 'react';
+import { UserEngagementMetrics } from '@/types/analytics';
+import { formatNumber, formatPercentage, calculateRetentionRate } from '@/services/analytics.service';
+
+interface UserEngagementCardProps {
+  metrics: UserEngagementMetrics;
+}
+
+interface MetricRowProps {
+  label: string;
+  value: string | number;
+  suffix?: string;
+  trend?: 'up' | 'down' | 'stable';
+}
+
+function MetricRow({ label, value, suffix, trend }: MetricRowProps) {
+  return (
+    <div className="flex items-center justify-between border-b border-slate-100 py-3 last:border-b-0">
+      <span className="text-sm font-medium text-slate-600">{label}</span>
+      <div className="flex items-center gap-2">
+        <span className="text-lg font-semibold text-slate-900">
+          {value}
+          {suffix && <span className="text-sm text-slate-500">{suffix}</span>}
+        </span>
+        {trend && (
+          <span className={`inline-block px-2 py-1 rounded text-xs font-medium ${
+            trend === 'up' ? 'bg-green-100 text-green-700' :
+            trend === 'down' ? 'bg-red-100 text-red-700' :
+            'bg-slate-100 text-slate-700'
+          }`}>
+            {trend === 'up' ? '↑' : trend === 'down' ? '↓' : '→'}
+          </span>
+        )}
+      </div>
+    </div>
+  );
+}
+
+export default function UserEngagementCard({ metrics }: UserEngagementCardProps) {
+  const retentionRate = calculateRetentionRate(metrics);
+  const growthDirection = metrics.growth_rate_pct > 0 ? 'up' : metrics.growth_rate_pct < 0 ? 'down' : 'stable';
+
+  return (
+    <div className="rounded-lg border border-slate-200 bg-white p-6">
+      <div className="mb-6">
+        <h2 className="text-lg font-bold text-slate-900">User Engagement</h2>
+        <p className="text-sm text-slate-500">Active users and engagement patterns</p>
+      </div>

+      <div className="space-y-2">
+        <MetricRow
+          label="Daily Active Users (DAU)"
+          value={formatNumber(metrics.dau)}
+          trend={growthDirection}
+        />
+        <MetricRow
+          label="Weekly Active Users (WAU)"
+          value={formatNumber(metrics.wau)}
+        />
+        <MetricRow
+          label="Monthly Active Users (MAU)"
+          value={formatNumber(metrics.mau)}
+        />
+        <MetricRow
+          label="Total Users"
+          value={formatNumber(metrics.total_users)}
+        />
+        <MetricRow
+          label="New Users"
+          value={formatNumber(metrics.new_users)}
+        />
+        <MetricRow
+          label="Growth Rate"
+          value={formatPercentage(metrics.growth_rate_pct).text}
+        />
+        <MetricRow
+          label="Retention Rate"
+          value={formatPercentage(retentionRate).text}
+        />
+        <MetricRow
+          label="Churn Rate"
+          value={formatPercentage(metrics.churn_rate_pct).text}
+        />
+        <MetricRow
+          label="Avg Session Duration"
+          value={metrics.avg_session_duration_minutes.toFixed(1)}
+          suffix=" minutes"
+        />
+      </div>

+      {/* Summary Stats */}
+      <div className="mt-6 grid grid-cols-2 gap-4 rounded-lg bg-slate-50 p-4">
+        <div>
+          <p className="text-xs font-semibold text-slate-600 uppercase">Active Users %</p>
+          <p className="mt-2 text-2xl font-bold text-slate-900">
+            {(metrics.dau / metrics.total_users * 100).toFixed(1)}%
+          </p>
+        </div>
+        <div>
+          <p className="text-xs font-semibold text-slate-600 uppercase">Weekly/Daily Ratio</p>
+          <p className="mt-2 text-2xl font-bold text-slate-900">
+            {(metrics.wau / metrics.dau).toFixed(2)}x
+          </p>
+        </div>
+      </div>
+    </div>
+  );
+}
