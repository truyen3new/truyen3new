+/**
+ * Analytics Service
+ * Utility functions for formatting and transforming analytics data
+ */
+
+import {
+  AnalyticsDashboard,
+  UserEngagementMetrics,
+  ContentPerformanceMetrics,
+  InfrastructureMetrics,
+  ChapterPerformance,
+} from '@/types/analytics';
+
+// ============================================================================
+// Number Formatting
+// ============================================================================
+
+/**
+ * Format large numbers with abbreviations (K, M, B)
+ */
+export function formatNumber(value: number, decimals: number = 1): string {
+  if (value === 0) return '0';
+  
+  const units = [
+    { threshold: 1e9, suffix: 'B' },
+    { threshold: 1e6, suffix: 'M' },
+    { threshold: 1e3, suffix: 'K' },
+  ];
+
+  for (const { threshold, suffix } of units) {
+    if (Math.abs(value) >= threshold) {
+      return `${(value / threshold).toFixed(decimals)}${suffix}`;
+    }
+  }

+  return value.toString();
+}
+
+/**
+ * Format percentage with sign and color hint
+ */
+export function formatPercentage(
+  value: number,
+  decimals: number = 1
+): { text: string; isPositive: boolean } {
+  const isPositive = value >= 0;
+  const sign = isPositive ? '+' : '';
+  return {
+    text: `${sign}${value.toFixed(decimals)}%`,
+    isPositive,
+  };
+}
+
+/**
+ * Format bytes as human-readable size
+ */
+export function formatBytes(bytes: number, decimals: number = 2): string {
+  if (bytes === 0) return '0 B';
+  
+  const units = ['B', 'KB', 'MB', 'GB', 'TB'];
+  const k = 1024;
+  const i = Math.floor(Math.log(bytes) / Math.log(k));
+
+  return `${(bytes / Math.pow(k, i)).toFixed(decimals)} ${units[i]}`;
+}
+
+/**
+ * Format milliseconds as readable duration
+ */
+export function formatDuration(ms: number): string {
+  if (ms < 1000) return `${Math.round(ms)}ms`;
+  if (ms < 60000) return `${(ms / 1000).toFixed(1)}s`;
+  return `${(ms / 60000).toFixed(1)}m`;
+}
+
+// ============================================================================
+// Analytics Calculations
+// ============================================================================
+
+/**
+ * Calculate growth trend direction
+ */
+export function getTrendDirection(
+  currentValue: number,
+  previousValue: number
+): 'up' | 'down' | 'stable' {
+  if (currentValue > previousValue * 1.05) return 'up';
+  if (currentValue < previousValue * 0.95) return 'down';
+  return 'stable';
+}
+
+/**
+ * Calculate engagement score efficiency
+ */
+export function getEngagementEfficiency(metrics: ContentPerformanceMetrics): number {
+  if (metrics.avg_views_per_chapter === 0) return 0;
+  return metrics.engagement_score / metrics.avg_views_per_chapter;
+}
+
+/**
+ * Get top performing chapters for display
+ */
+export function getTopPerformingChapters(
+  metrics: ContentPerformanceMetrics,
+  limit: number = 5
+): ChapterPerformance[] {
+  return metrics.top_chapters.slice(0, limit);
+}
+
+/**
+ * Calculate user retention rate
+ */
+export function calculateRetentionRate(metrics: UserEngagementMetrics): number {
+  if (metrics.total_users === 0) return 0;
+  return 100 - metrics.churn_rate_pct;
+}
+
+/**
+ * Determine infrastructure health status
+ */
+export function getInfrastructureHealth(metrics: InfrastructureMetrics): 'healthy' | 'warning' | 'critical' {
+  // Composite score based on multiple factors
+  const latencyScore = metrics.avg_db_latency_ms ? 
+    (metrics.avg_db_latency_ms > 100 ? 0 : 1) : 1;
+  const cacheScore = metrics.cache_hit_ratio_pct ? 
+    (metrics.cache_hit_ratio_pct > 70 ? 1 : 0) : 1;
+  
+  const health = (latencyScore + cacheScore) / 2;
+  if (health > 0.8) return 'healthy';
+  if (health > 0.5) return 'warning';
+  return 'critical';
+}
