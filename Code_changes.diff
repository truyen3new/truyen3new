+-- ============================================================================
+-- Analytics Dashboard: RPC Functions & Indexes for Light Story
+-- Version: 1.0
+-- Deployment Date: May 7, 2026
+-- ============================================================================
+
+-- ============================================================================
+-- SECTION 1: Create Required Indexes for Performance
+-- ============================================================================
+
+-- Index on story_views for engagement metrics (critical)
+CREATE INDEX IF NOT EXISTS idx_story_views_viewed_at 
+  ON story_views(viewed_at DESC)
+  WHERE viewed_at > NOW() - INTERVAL '90 days';
+
+CREATE INDEX IF NOT EXISTS idx_story_views_viewed_by_viewed_at 
+  ON story_views(viewed_by, viewed_at DESC);
+
+-- Index on story_likes for content performance
+CREATE INDEX IF NOT EXISTS idx_story_likes_created_at 
+  ON story_likes(created_at DESC)
+  WHERE created_at > NOW() - INTERVAL '90 days';
+
+-- Index on profiles for user cohorts
+CREATE INDEX IF NOT EXISTS idx_profiles_created_at 
+  ON profiles(created_at DESC);
+
+-- Index on stories for ranking
+CREATE INDEX IF NOT EXISTS idx_stories_views 
+  ON stories(views DESC);
+
+-- Index on chapters for story drill-down
+CREATE INDEX IF NOT EXISTS idx_chapters_story_id_created_at 
+  ON chapters(story_id, created_at DESC);
+
+-- Index on chapter_images for storage tracking
+CREATE INDEX IF NOT EXISTS idx_chapter_images_created_at 
+  ON chapter_images(created_at DESC)
+  WHERE created_at > NOW() - INTERVAL '90 days';
+
+-- ============================================================================
+-- SECTION 2: User Engagement Metrics RPC
+-- ============================================================================
+
+CREATE OR REPLACE FUNCTION get_user_engagement_metrics(
+    p_time_range INTERVAL DEFAULT '24 hours'::INTERVAL,
+    p_limit INT DEFAULT 100
+) RETURNS TABLE (
+    total_users BIGINT,
+    new_users BIGINT,
+    growth_rate_pct NUMERIC,
+    active_users BIGINT,
+    dau BIGINT,
+    wau BIGINT,
+    mau BIGINT,
+    churn_rate_pct NUMERIC,
+    avg_session_duration_minutes NUMERIC
+) LANGUAGE SQL STABLE AS $$
+WITH time_windows AS (
+    SELECT 
+        NOW() - p_time_range AS period_start,
+        NOW() AS period_end,
+        NOW() - '7 days'::INTERVAL AS week_start,
+        NOW() - '30 days'::INTERVAL AS month_start,
+        NOW() - (p_time_range * 2) AS prev_period_start
+),
+user_cohorts AS (
+    SELECT 
+        p.id,
+        p.created_at,
+        CASE WHEN sv.viewed_at > (SELECT period_start FROM time_windows)
+             THEN 1 ELSE 0 END AS is_active_current,
+        CASE WHEN sv.viewed_at > (SELECT period_start FROM time_windows) - '14 days'::INTERVAL
+             THEN 1 ELSE 0 END AS was_active_prev,
+        CASE WHEN p.created_at > (SELECT period_start FROM time_windows)
+             THEN 1 ELSE 0 END AS is_new,
+        MAX(sv.viewed_at) AS last_view_at
+    FROM profiles p
+    LEFT JOIN story_views sv ON p.id = sv.viewed_by
+    WHERE p.role NOT IN ('superadmin', 'admin')
+        AND p.created_at <= NOW()
+    GROUP BY p.id, p.created_at
+),
+active_stats AS (
+    SELECT 
+        COUNT(DISTINCT uc.id) AS dau_count,
+        COUNT(DISTINCT CASE WHEN uc.last_view_at > (SELECT week_start FROM time_windows)
+            THEN uc.id END) AS wau_count,
+        COUNT(DISTINCT CASE WHEN uc.last_view_at > (SELECT month_start FROM time_windows)
+            THEN uc.id END) AS mau_count,
+        COUNT(DISTINCT CASE WHEN uc.is_new = 1 THEN uc.id END) AS new_count,
+        COUNT(DISTINCT uc.id) AS total_count,
+        COUNT(DISTINCT CASE WHEN uc.is_active_current = 1 THEN uc.id END) AS active_count
+    FROM user_cohorts uc
+),
+churn_calc AS (
+    SELECT 
+        ROUND(
+            COUNT(DISTINCT CASE WHEN uc.is_active_current = 0 AND uc.was_active_prev = 1
+                THEN uc.id END)::NUMERIC / NULLIF(
+                    COUNT(DISTINCT CASE WHEN uc.was_active_prev = 1 THEN uc.id END),
+                    0
+                ) * 100,
+            2
+        ) AS churn_pct
+    FROM user_cohorts uc
+),
+growth_calc AS (
+    SELECT 
+        ROUND(
+            ((SELECT dau_count FROM active_stats)::NUMERIC - 
+             (SELECT COUNT(DISTINCT CASE WHEN uc.last_view_at > (SELECT prev_period_start FROM time_windows)
+                                          AND uc.last_view_at <= (SELECT period_start FROM time_windows)
+                                     THEN uc.id END) FROM user_cohorts uc)::NUMERIC) /
+            NULLIF((SELECT COUNT(DISTINCT CASE WHEN uc.last_view_at > (SELECT prev_period_start FROM time_windows)
+                                                AND uc.last_view_at <= (SELECT period_start FROM time_windows)
+                                           THEN uc.id END) FROM user_cohorts uc)::NUMERIC, 0) * 100,
+            2
+        ) AS growth_pct
+),
+avg_duration_calc AS (
+    SELECT AVG(session_minutes)::NUMERIC AS avg_minutes
+    FROM (
+        SELECT 
+            COUNT(DISTINCT viewed_at)::NUMERIC / 
+            NULLIF(EXTRACT(EPOCH FROM (MAX(viewed_at) - MIN(viewed_at))) / 60, 0) AS session_minutes
+        FROM story_views
+        WHERE viewed_at > (SELECT period_start FROM time_windows)
+        GROUP BY viewed_by
+        LIMIT p_limit
+    ) sessions
+)
+SELECT 
+    (SELECT total_count FROM active_stats),
+    (SELECT new_count FROM active_stats),
+    COALESCE((SELECT growth_pct FROM growth_calc), 0),
+    (SELECT active_count FROM active_stats),
+    (SELECT dau_count FROM active_stats),
+    (SELECT wau_count FROM active_stats),
+    (SELECT mau_count FROM active_stats),
+    COALESCE((SELECT churn_pct FROM churn_calc), 0),
+    COALESCE((SELECT avg_minutes FROM avg_duration_calc), 0)
+$$;
+
+-- Grant execution to authenticated users
+GRANT EXECUTE ON FUNCTION get_user_engagement_metrics(INTERVAL, INT) TO authenticated, anon;
+GRANT EXECUTE ON FUNCTION get_user_engagement_metrics TO authenticated, anon;
+
+-- ============================================================================
+-- SECTION 3: Content Performance RPC
+-- ============================================================================
+
+CREATE OR REPLACE FUNCTION get_content_performance(
+    p_time_range INTERVAL DEFAULT '7 days'::INTERVAL,
+    p_limit INT DEFAULT 10
+) RETURNS TABLE (
+    top_chapters JSONB,
+    total_views BIGINT,
+    avg_views_per_chapter NUMERIC,
+    engagement_score NUMERIC
+) LANGUAGE SQL STABLE AS $$
+WITH content_stats AS (
+    SELECT 
+        c.id AS chapter_id,
+        c.story_id,
+        c.chapter_number,
+        c.title,
+        COUNT(sv.id)::BIGINT AS view_count,
+        COALESCE(COUNT(DISTINCT CASE WHEN sl.created_at > NOW() - p_time_range THEN sl.id END), 0)::INT AS like_count,
+        (COUNT(sv.id)::NUMERIC + (COALESCE(COUNT(DISTINCT CASE WHEN sl.created_at > NOW() - p_time_range THEN sl.id END), 0)::NUMERIC * 2)))::INT AS engagement_score,
+        ROW_NUMBER() OVER (ORDER BY COUNT(sv.id) DESC) AS rank
+    FROM chapters c
+    LEFT JOIN story_views sv ON c.story_id = sv.story_id
+        AND sv.viewed_at > NOW() - p_time_range
+    LEFT JOIN story_likes sl ON c.story_id = sl.story_id
+    WHERE c.created_at <= NOW()
+    GROUP BY c.id, c.story_id, c.chapter_number, c.title
+),
+top_content AS (
+    SELECT 
+        jsonb_agg(jsonb_build_object(
+            'chapter_id', chapter_id,
+            'story_id', story_id,
+            'chapter_number', chapter_number,
+            'title', title,
+            'views', view_count,
+            'likes', like_count,
+            'engagement_score', engagement_score,
+            'rank', rank
+        ) ORDER BY rank ASC) FILTER (WHERE rank <= p_limit) AS chapters,
+        SUM(view_count)::BIGINT AS total_views,
+        AVG(view_count)::NUMERIC AS avg_views,
+        AVG(engagement_score)::NUMERIC AS avg_engagement
+    FROM content_stats
+)
+SELECT 
+    COALESCE(tc.chapters, '[]'::JSONB),
+    COALESCE(tc.total_views, 0),
+    COALESCE(tc.avg_views, 0),
+    COALESCE(tc.avg_engagement, 0)
+FROM top_content tc
+$$;
+
+GRANT EXECUTE ON FUNCTION get_content_performance(INTERVAL, INT) TO authenticated, anon;
+GRANT EXECUTE ON FUNCTION get_content_performance TO authenticated, anon;
+
+-- ============================================================================
+-- SECTION 4: Storage & Infrastructure Metrics RPC
+-- ============================================================================
+
+CREATE OR REPLACE FUNCTION get_storage_metrics(
+    p_time_range INTERVAL DEFAULT '30 days'::INTERVAL
+) RETURNS TABLE (
+    r2_usage_gb NUMERIC,
+    r2_object_count BIGINT,
+    d1_size_bytes BIGINT,
+    chapter_images_count BIGINT,
+    storage_efficiency_pct NUMERIC
+) LANGUAGE SQL STABLE AS $$
+WITH storage_summary AS (
+    SELECT 
+        COUNT(DISTINCT ci.id) AS image_count,
+        COALESCE(SUM(ci.size_bytes), 0)::BIGINT AS total_size_bytes,
+        COUNT(DISTINCT c.id) AS chapter_count,
+        COUNT(DISTINCT s.id) AS story_count
+    FROM chapter_images ci
+    LEFT JOIN chapters c ON ci.chapter_id = c.id
+    LEFT JOIN stories s ON c.story_id = s.id
+    WHERE ci.created_at > NOW() - p_time_range
+)
+SELECT 
+    (total_size_bytes::NUMERIC / 1024 / 1024 / 1024)::NUMERIC,
+    image_count,
+    (story_count * 1048576)::BIGINT,
+    image_count,
+    ROUND(
+        (chapter_count::NUMERIC / NULLIF(image_count::NUMERIC, 0) * 100),
+        2
+    )
+FROM storage_summary
+$$;
+
+GRANT EXECUTE ON FUNCTION get_storage_metrics(INTERVAL) TO authenticated, anon;
+GRANT EXECUTE ON FUNCTION get_storage_metrics TO authenticated, anon;
+
+-- ============================================================================
+-- SECTION 5: Materialized View for Dashboard Cache (Optional but Recommended)
+-- ============================================================================
+
+CREATE MATERIALIZED VIEW IF NOT EXISTS mv_analytics_cache AS
+SELECT 
+    'user_engagement'::TEXT AS metric_type,
+    jsonb_build_object(
+        'timestamp', NOW(),
+        'data', row_to_json(get_user_engagement_metrics('24 hours'::INTERVAL))
+    ) AS cached_data,
+    NOW() AS last_refresh
+UNION ALL
+SELECT 
+    'content_performance'::TEXT,
+    jsonb_build_object(
+        'timestamp', NOW(),
+        'data', row_to_json(get_content_performance('7 days'::INTERVAL))
+    ),
+    NOW()
+UNION ALL
+SELECT 
+    'storage_metrics'::TEXT,
+    jsonb_build_object(
+        'timestamp', NOW(),
+        'data', row_to_json(get_storage_metrics('30 days'::INTERVAL))
+    ),
+    NOW();
+
+-- Refresh policy (optional - requires pg_cron)
+-- SELECT cron.schedule('refresh_analytics_cache', '*/5 * * * *', 
+--   'REFRESH MATERIALIZED VIEW CONCURRENTLY mv_analytics_cache');
+
+-- ============================================================================
+-- SECTION 6: Row Level Security (RLS) Policies
+-- ============================================================================
+
+-- Enable RLS on story_views (if not already enabled)
+ALTER TABLE story_views ENABLE ROW LEVEL SECURITY;
+
+-- Policy: Only admins can query historical analytics
+CREATE POLICY analytics_admin_read ON story_views
+    FOR SELECT
+    USING (
+        EXISTS (
+            SELECT 1 FROM profiles p 
+            WHERE p.id = auth.uid() 
+            AND p.role IN ('superadmin', 'admin')
+        )
+    );
+
+-- ============================================================================
+-- Migration Complete
+-- ============================================================================
