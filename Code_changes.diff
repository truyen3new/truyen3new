+/**
+ * Analytics Dashboard Types
+ * Defines all interfaces and types for the Analytics Dashboard
+ */
+
+export type TimeRange = '24h' | '7d' | '30d' | 'custom';
+
+export interface DateRange {
+  start: Date;
+  end: Date;
+}
+
+/**
+ * User Engagement Metrics
+ */
+export interface UserEngagementMetrics {
+  total_users: number;
+  new_users: number;
+  growth_rate_pct: number;
+  active_users: number;
+  dau: number; // Daily Active Users
+  wau: number; // Weekly Active Users
+  mau: number; // Monthly Active Users
+  churn_rate_pct: number;
+  avg_session_duration_minutes: number;
+}
+
+/**
+ * Chapter Performance Details
+ */
+export interface ChapterPerformance {
+  chapter_id: string;
+  story_id: string;
+  chapter_number: number;
+  title: string;
+  views: number;
+  likes: number;
+  engagement_score: number;
+  rank: number;
+}
+
+/**
+ * Content Performance Metrics
+ */
+export interface ContentPerformanceMetrics {
+  top_chapters: ChapterPerformance[];
+  total_views: number;
+  avg_views_per_chapter: number;
+  engagement_score: number;
+}
+
+/**
+ * Infrastructure / Storage Metrics
+ */
+export interface InfrastructureMetrics {
+  r2_usage_gb: number;
+  r2_object_count: number;
+  r2_egress_gb?: number;
+  d1_size_bytes: number;
+  d1_queries_count?: number;
+  avg_db_latency_ms?: number;
+  storage_efficiency_pct: number;
+  cache_hit_ratio_pct?: number;
+}
+
+/**
+ * Analytics Dashboard Response Metadata
+ */
+export interface AnalyticsMeta {
+  timestamp: string; // ISO 8601
+  range: TimeRange;
+  range_start: string; // ISO 8601
+  range_end: string; // ISO 8601
+  cached: boolean;
+  cache_ttl_seconds: number;
+  request_id: string;
+}
+
+/**
+ * Complete Analytics Dashboard Response
+ */
+export interface AnalyticsDashboard {
+  meta: AnalyticsMeta;
+  user_engagement: UserEngagementMetrics;
+  content_performance: ContentPerformanceMetrics;
+  infrastructure: InfrastructureMetrics;
+}
+
+/**
+ * API Request/Response Errors
+ */
+export interface AnalyticsError {
+  error_code: string;
+  message: string;
+  details?: Record<string, unknown>;
+  timestamp: string;
+}
+
+/**
+ * Analytics Query Parameters
+ */
+export interface AnalyticsQueryParams {
+  range?: TimeRange;
+  start_date?: string; // ISO 8601
+  end_date?: string; // ISO 8601
+  role_filter?: string;
+  cache_bypass?: boolean;
+}
+
+/**
+ * Component State Types
+ */
+export interface AnalyticsDashboardState {
+  data: AnalyticsDashboard | null;
+  isLoading: boolean;
+  error: AnalyticsError | null;
+  selectedRange: TimeRange;
+  lastRefresh: Date | null;
+  isCached: boolean;
+}
+
+/**
+ * Hook Return Type
+ */
+export interface UseAnalyticsDashboardReturn {
+  data: AnalyticsDashboard | null;
+  isLoading: boolean;
+  error: AnalyticsError | null;
+  refetch: () => Promise<void>;
+  setTimeRange: (range: TimeRange) => void;
+}
