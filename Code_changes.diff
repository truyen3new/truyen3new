+/**
+ * Analytics Dashboard Tab
+ * Main component for the admin analytics dashboard
+ */
+
+'use client';
+
+import React, { useCallback, useMemo } from 'react';
+import { useAnalyticsDashboard } from '@/_presenters/useAnalyticsDashboard';
+import { TimeRange, AnalyticsDashboard } from '@/types/analytics';
+import {
+  formatNumber,
+  formatPercentage,
+  formatBytes,
+  formatDuration,
+  getInfrastructureHealth,
+} from '@/services/analytics.service';
+import UserEngagementCard from './analytics/UserEngagementCard';
+import ContentPerformanceCard from './analytics/ContentPerformanceCard';
+import InfrastructureCard from './analytics/InfrastructureCard';
+
+// ============================================================================
+// Constants
+// ============================================================================
+
+const TIME_RANGES: Array<{ value: TimeRange; label: string }> = [
+  { value: '24h', label: 'Last 24 Hours' },
+  { value: '7d', label: 'Last 7 Days' },
+  { value: '30d', label: 'Last 30 Days' },
+];
+
+// ============================================================================
+// Components
+// ============================================================================
+
+interface MetricDisplayProps {
+  label: string;
+  value: string | number;
+  subtext?: string;
+  className?: string;
+}
+
+function MetricDisplay({ label, value, subtext, className = '' }: MetricDisplayProps) {
+  return (
+    <div className={`rounded-lg border border-slate-200 bg-white p-4 ${className}`}>
+      <p className="text-sm font-medium text-slate-600">{label}</p>
+      <p className="mt-2 text-2xl font-bold text-slate-900">{value}</p>
+      {subtext && <p className="mt-1 text-xs text-slate-500">{subtext}</p>}
+    </div>
+  );
+}
+
+interface TimeRangeSelectorProps {
+  selectedRange: TimeRange;
+  onRangeChange: (range: TimeRange) => void;
+  isLoading?: boolean;
+}
+
+function TimeRangeSelector({
+  selectedRange,
+  onRangeChange,
+  isLoading = false,
+}: TimeRangeSelectorProps) {
+  return (
+    <div className="flex gap-2">
+      {TIME_RANGES.map(({ value, label }) => (
+        <button
+          key={value}
+          onClick={() => onRangeChange(value)}
+          disabled={isLoading}
+          className={`rounded-lg px-4 py-2 text-sm font-medium transition-colors ${
+            selectedRange === value
+              ? 'bg-blue-600 text-white'
+              : 'bg-slate-100 text-slate-700 hover:bg-slate-200'
+          } disabled:opacity-50 disabled:cursor-not-allowed`}
+        >
+          {label}
+        </button>
+      ))}
+    </div>
+  );
+}
+
+interface LoadingStateProps {
+  message?: string;
+}
+
+function LoadingState({ message = 'Loading analytics dashboard...' }: LoadingStateProps) {
+  return (
+    <div className="flex items-center justify-center rounded-lg border border-slate-200 bg-slate-50 p-12">
+      <div className="text-center">
+        <div className="mb-4 inline-block">
+          <div className="h-8 w-8 animate-spin rounded-full border-4 border-slate-200 border-t-blue-600" />
+        </div>
+        <p className="text-slate-600">{message}</p>
+      </div>
+    </div>
+  );
+}
+
+interface ErrorStateProps {
+  error: string | null;
+  onRetry: () => void;
+}
+
+function ErrorState({ error, onRetry }: ErrorStateProps) {
+  return (
+    <div className="rounded-lg border border-red-200 bg-red-50 p-6">
+      <h3 className="font-semibold text-red-900">Error Loading Analytics</h3>
+      <p className="mt-2 text-sm text-red-700">{error}</p>
+      <button
+        onClick={onRetry}
+        className="mt-4 rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700"
+      >
+        Try Again
+      </button>
+    </div>
+  );
+}
+
+interface RefreshIndicatorProps {
+  timestamp: string;
+  isCached: boolean;
+  onRefresh: () => void;
+  isLoading?: boolean;
+}
+
+function RefreshIndicator({
+  timestamp,
+  isCached,
+  onRefresh,
+  isLoading = false,
+}: RefreshIndicatorProps) {
+  const formattedTime = new Date(timestamp).toLocaleTimeString();
+
+  return (
+    <div className="flex items-center justify-between text-xs text-slate-500">
+      <div>
+        <span>Last updated: {formattedTime}</span>
+        {isCached && <span className="ml-2 rounded-full bg-amber-100 px-2 py-1 text-amber-700">(cached)</span>}
+      </div>
+      <button
+        onClick={onRefresh}
+        disabled={isLoading}
+        className="rounded-lg bg-slate-100 px-3 py-1 text-slate-600 hover:bg-slate-200 disabled:opacity-50"
+      >
+        {isLoading ? 'Refreshing...' : 'Refresh'}
+      </button>
+    </div>
+  );
+}
+
+// ============================================================================
+// Main Component
+// ============================================================================
+
+export default function AnalyticsDashboardTab() {
+  const { data, isLoading, error, refetch, setTimeRange } = useAnalyticsDashboard('24h');
+  const [manualTimeRange, setManualTimeRange] = React.useState<TimeRange>('24h');
+
+  const handleTimeRangeChange = useCallback(
+    (range: TimeRange) => {
+      setManualTimeRange(range);
+      setTimeRange(range);
+    },
+    [setTimeRange]
+  );
+
+  const infrastructureHealth = useMemo(() => {
+    if (!data?.infrastructure) return 'unknown';
+    return getInfrastructureHealth(data.infrastructure);
+  }, [data?.infrastructure]);
+
+  const errorMessage = error?.message || null;
+
+  return (
+    <div className="space-y-6 p-6">
+      {/* Header Section */}
+      <div className="flex items-center justify-between">
+        <div>
+          <h1 className="text-3xl font-bold text-slate-900">Analytics Dashboard</h1>
+          <p className="mt-1 text-slate-600">Real-time insights into platform performance</p>
+        </div>
+        <div className="text-right">
+          <div className="text-sm font-medium text-slate-900">Infrastructure Status</div>
+          <div className={`mt-1 text-sm font-semibold ${
+            infrastructureHealth === 'healthy' ? 'text-green-600' :
+            infrastructureHealth === 'warning' ? 'text-amber-600' :
+            infrastructureHealth === 'critical' ? 'text-red-600' :
+            'text-slate-600'
+          }`}>
+            {infrastructureHealth.charAt(0).toUpperCase() + infrastructureHealth.slice(1)}
+          </div>
+        </div>
+      </div>

+      {/* Time Range Selector */}
+      <TimeRangeSelector
+        selectedRange={manualTimeRange}
+        onRangeChange={handleTimeRangeChange}
+        isLoading={isLoading}
+      />

+      {/* Error State */}
+      {errorMessage && (
+        <ErrorState error={errorMessage} onRetry={() => refetch()} />
+      )}

+      {/* Loading State */}
+      {isLoading && !data && (
+        <LoadingState />
+      )}

+      {/* Main Content */}
+      {data && (
+        <>
+          {/* Quick Stats */}
+          <div className="grid grid-cols-1 gap-4 md:grid-cols-4">
+            <MetricDisplay
+              label="Total Users"
+              value={formatNumber(data.user_engagement.total_users)}
+              subtext={`+${formatNumber(data.user_engagement.new_users)} new`}
+            />
+            <MetricDisplay
+              label="DAU"
+              value={formatNumber(data.user_engagement.dau)}
+              subtext={formatPercentage(data.user_engagement.growth_rate_pct).text}
+            />
+            <MetricDisplay
+              label="Total Views"
+              value={formatNumber(data.content_performance.total_views)}
+              subtext={`Avg: ${formatNumber(data.content_performance.avg_views_per_chapter)}`}
+            />
+            <MetricDisplay
+              label="Storage Used"
+              value={formatBytes(data.infrastructure.d1_size_bytes + (data.infrastructure.r2_usage_gb * 1e9))}
+              subtext={`R2: ${formatNumber(data.infrastructure.r2_object_count)} objects`}
+            />
+          </div>

+          {/* Detailed Cards */}
+          <div className="grid grid-cols-1 gap-6 lg:grid-cols-2">
+            <UserEngagementCard metrics={data.user_engagement} />
+            <ContentPerformanceCard metrics={data.content_performance} />
+          </div>

+          {/* Infrastructure Card */}
+          <div className="lg:col-span-2">
+            <InfrastructureCard metrics={data.infrastructure} />
+          </div>

+          {/* Refresh Indicator */}
+          <RefreshIndicator
+            timestamp={data.meta.timestamp}
+            isCached={data.meta.cached}
+            onRefresh={() => refetch()}
+            isLoading={isLoading}
+          />
+        </>
+      )}
+    </div>
+  );
+}
