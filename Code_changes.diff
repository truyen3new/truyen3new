+/**
+ * React Query Hook for Analytics Dashboard
+ * Manages fetching, caching, and refetching of analytics data
+ */
+
+'use client';
+
+import { useCallback, useState } from 'react';
+import { useQuery, UseQueryResult } from '@tanstack/react-query';
+import {
+  AnalyticsDashboard,
+  AnalyticsError,
+  TimeRange,
+  UseAnalyticsDashboardReturn,
+} from '@/types/analytics';
+
+// ============================================================================
+// Constants
+// ============================================================================
+
+const QUERY_KEY_BASE = ['analytics', 'dashboard'];
+const STALE_TIME_MS = 5 * 60 * 1000; // 5 minutes
+const CACHE_TIME_MS = 10 * 60 * 1000; // 10 minutes
+const RETRY_ATTEMPTS = 3;
+const RETRY_DELAY_MS = 1000;
+
+// ============================================================================
+// Fetcher Function
+// ============================================================================
+
+async function fetchAnalyticsDashboard(
+  timeRange: TimeRange,
+  bypassCache: boolean = false
+): Promise<AnalyticsDashboard> {
+  const searchParams = new URLSearchParams({
+    range: timeRange,
+    ...(bypassCache && { cache_bypass: 'true' }),
+  });
+
+  const response = await fetch(
+    `/api/internal/admin/analytics/dashboard?${searchParams.toString()}`,
+    {
+      method: 'GET',
+      headers: {
+        'Content-Type': 'application/json',
+        'Accept': 'application/json',
+      },
+      credentials: 'include', // Include cookies for auth
+    }
+  );

+  if (!response.ok) {
+    const errorData = await response.json().catch(() => ({}));
+    const error = new Error(
+      errorData.message || `Analytics API error: ${response.status}`
+    ) as Error & { status: number; data: AnalyticsError };
+    error.status = response.status;
+    error.data = errorData;
+    throw error;
+  }

+  const data: AnalyticsDashboard = await response.json();
+  return data;
+}
+
+// ============================================================================
+// Hook Implementation
+// ============================================================================
+
+export function useAnalyticsDashboard(
+  initialTimeRange: TimeRange = '24h'
+): UseAnalyticsDashboardReturn {
+  const [timeRange, setTimeRangeState] = useState<TimeRange>(initialTimeRange);
+  const [shouldBypassCache, setShouldBypassCache] = useState(false);

+  // React Query hook
+  const queryResult: UseQueryResult<AnalyticsDashboard, Error> = useQuery({
+    queryKey: [...QUERY_KEY_BASE, timeRange],
+    queryFn: () => fetchAnalyticsDashboard(timeRange, shouldBypassCache),
+    staleTime: STALE_TIME_MS,
+    gcTime: CACHE_TIME_MS,
+    retry: RETRY_ATTEMPTS,
+    retryDelay: (attemptIndex) => {
+      return RETRY_DELAY_MS * Math.pow(2, attemptIndex);
+    },
+    refetchInterval: (query) => {
+      // Auto-refetch every 5 minutes if data is stale
+      if (query.state.status === 'success') {
+        return STALE_TIME_MS;
+      }
+      return false;
+    },
+    enabled: true, // Always fetch on mount
+  });

+  // Convert error to our custom type
+  let analyticsError: AnalyticsError | null = null;
+  if (queryResult.error) {
+    analyticsError = {
+      error_code: (queryResult.error as any).data?.error_code || 'UNKNOWN_ERROR',
+      message: queryResult.error.message || 'Failed to fetch analytics',
+      timestamp: new Date().toISOString(),
+      details: (queryResult.error as any).data?.details,
+    };
+  }

+  // Refetch function
+  const refetch = useCallback(async () => {
+    setShouldBypassCache(true);
+    try {
+      await queryResult.refetch();
+    } finally {
+      setShouldBypassCache(false);
+    }
+  }, [queryResult]);

+  // Update time range
+  const setTimeRange = useCallback(
+    (newRange: TimeRange) => {
+      setTimeRangeState(newRange);
+    },
+    []
+  );

+  return {
+    data: queryResult.data || null,
+    isLoading: queryResult.isLoading,
+    error: analyticsError,
+    refetch,
+    setTimeRange,
+  };
+}
+
+// Export query utilities for testing/debugging
+export function getAnalyticsDashboardQueryKey(timeRange: TimeRange = '24h') {
+  return [...QUERY_KEY_BASE, timeRange];
+}
