+/**
+ * Infrastructure Card Component
+ * Displays storage, latency, and caching metrics
+ */
+
+'use client';
+
+import React from 'react';
+import { InfrastructureMetrics } from '@/types/analytics';
+import { formatNumber, formatBytes, formatDuration } from '@/services/analytics.service';
+
+interface InfrastructureCardProps {
+  metrics: InfrastructureMetrics;
+}
+
+interface MetricBoxProps {
+  label: string;
+  value: string | number;
+  subtext?: string;
+  status?: 'healthy' | 'warning' | 'critical';
+}
+
+function MetricBox({ label, value, subtext, status }: MetricBoxProps) {
+  const statusColor = {
+    healthy: 'border-green-200 bg-green-50',
+    warning: 'border-amber-200 bg-amber-50',
+    critical: 'border-red-200 bg-red-50',
+  }[status || 'healthy'];
+
+  const textColor = {
+    healthy: 'text-green-900',
+    warning: 'text-amber-900',
+    critical: 'text-red-900',
+  }[status || 'healthy'];
+
+  return (
+    <div className={`rounded-lg border p-4 ${statusColor}`}>
+      <p className={`text-sm font-medium ${textColor}`}>{label}</p>
+      <p className={`mt-2 text-2xl font-bold ${textColor}`}>{value}</p>
+      {subtext && <p className={`mt-1 text-xs ${textColor} opacity-75`}>{subtext}</p>}
+    </div>
+  );
+}
+
+export default function InfrastructureCard({ metrics }: InfrastructureCardProps) {
+  // Determine status indicators
+  const latencyStatus = metrics.avg_db_latency_ms ? (
+    metrics.avg_db_latency_ms > 100 ? 'critical' :
+    metrics.avg_db_latency_ms > 50 ? 'warning' :
+    'healthy'
+  ) : 'healthy';
+
+  const cacheStatus = metrics.cache_hit_ratio_pct ? (
+    metrics.cache_hit_ratio_pct > 80 ? 'healthy' :
+    metrics.cache_hit_ratio_pct > 60 ? 'warning' :
+    'critical'
+  ) : 'healthy';
+
+  const storageStatus = metrics.r2_usage_gb > 1000 ? 'warning' : 'healthy';
+
+  const totalStorage = metrics.r2_usage_gb * 1e9 + metrics.d1_size_bytes;
+
+  return (
+    <div className="rounded-lg border border-slate-200 bg-white p-6">
+      <div className="mb-6">
+        <h2 className="text-lg font-bold text-slate-900">Infrastructure & Storage</h2>
+        <p className="text-sm text-slate-500">Cloud infrastructure metrics</p>
+      </div>

+      {/* Storage Section */}
+      <div className="mb-8">
+        <h3 className="mb-4 text-sm font-semibold text-slate-900">Storage Metrics</h3>
+        <div className="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
+          <MetricBox
+            label="R2 Usage"
+            value={formatNumber(metrics.r2_usage_gb, 1) + ' GB'}
+            subtext={`${formatNumber(metrics.r2_object_count)} objects`}
+            status={storageStatus}
+          />
+          <MetricBox
+            label="D1 Database"
+            value={formatBytes(metrics.d1_size_bytes)}
+            subtext="PostgreSQL size"
+          />
+          <MetricBox
+            label="Total Storage"
+            value={formatBytes(totalStorage)}
+            subtext={`${formatPercentage((totalStorage / (2e12)) * 100, 1).text} of 2TB quota`}
+          />
+          <MetricBox
+            label="Storage Efficiency"
+            value={metrics.storage_efficiency_pct.toFixed(1) + '%'}
+            subtext="Compression ratio"
+          />
+        </div>
+      </div>

+      {/* Performance Section */}
+      <div className="mb-8">
+        <h3 className="mb-4 text-sm font-semibold text-slate-900">Performance Metrics</h3>
+        <div className="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
+          <MetricBox
+            label="DB Latency (p95)"
+            value={formatDuration(metrics.avg_db_latency_ms || 0)}
+            subtext="Query response time"
+            status={latencyStatus}
+          />
+          <MetricBox
+            label="Cache Hit Ratio"
+            value={(metrics.cache_hit_ratio_pct || 0).toFixed(1) + '%'}
+            subtext="Edge cache effectiveness"
+            status={cacheStatus}
+          />
+          <MetricBox
+            label="DB Queries"
+            value={formatNumber(metrics.d1_queries_count || 0)}
+            subtext="24h volume"
+          />
+          <MetricBox
+            label="R2 Egress"
+            value={formatNumber(metrics.r2_egress_gb || 0, 1) + ' GB'}
+            subtext="Data served today"
+          />
+        </div>
+      </div>

+      {/* Status Summary */}
+      <div className="rounded-lg bg-slate-50 p-4">
+        <h3 className="mb-3 text-sm font-semibold text-slate-900">Status Summary</h3>
+        <div className="space-y-2">
+          <div className="flex items-center justify-between">
+            <span className="text-sm text-slate-600">Database Performance</span>
+            <span className={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${
+              latencyStatus === 'healthy' ? 'bg-green-100 text-green-700' :
+              latencyStatus === 'warning' ? 'bg-amber-100 text-amber-700' :
+              'bg-red-100 text-red-700'
+            }`}>
+              {latencyStatus.charAt(0).toUpperCase() + latencyStatus.slice(1)}
+            </span>
+          </div>
+          <div className="flex items-center justify-between">
+            <span className="text-sm text-slate-600">Cache Effectiveness</span>
+            <span className={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${
+              cacheStatus === 'healthy' ? 'bg-green-100 text-green-700' :
+              cacheStatus === 'warning' ? 'bg-amber-100 text-amber-700' :
+              'bg-red-100 text-red-700'
+            }`}>
+              {cacheStatus.charAt(0).toUpperCase() + cacheStatus.slice(1)}
+            </span>
+          </div>
+          <div className="flex items-center justify-between">
+            <span className="text-sm text-slate-600">Storage Capacity</span>
+            <span className={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${
+              storageStatus === 'healthy' ? 'bg-green-100 text-green-700' :
+              'bg-amber-100 text-amber-700'
+            }`}>
+              {storageStatus.charAt(0).toUpperCase() + storageStatus.slice(1)}
+            </span>
+          </div>
+        </div>
+      </div>
+    </div>
+  );
+}
+
+// Helper function (should be imported from service)
+function formatPercentage(value: number, decimals: number = 1): { text: string; isPositive: boolean } {
+  const isPositive = value >= 0;
+  const sign = isPositive ? '+' : '';
+  return {
+    text: `${sign}${value.toFixed(decimals)}%`,
+    isPositive,
+  };
+}
diff --git a/backend-d1-saas/src/analytics-aggregator.ts b/backend-d1-saas/src/analytics-aggregator.ts
new file mode 100644
index 0000000..7a5bfac
--- /dev/null
+++ b/backend-d1-saas/src/analytics-aggregator.ts
@@ -0,0 +1,228 @@
+/**
+ * Cloudflare Worker: Analytics Aggregator
+ * Fetches metrics from Cloudflare APIs and D1/R2 and returns aggregated data
+ * 
+ * Deployed as: aggregates.analytics-dashboard
+ * Endpoint: GET https://aggregates.analytics-dashboard.{account}.workers.dev/metrics
+ * 
+ * Environment Variables:
+ * - CF_ACCOUNT_ID: Cloudflare account ID
+ * - CF_API_TOKEN: Cloudflare API token (with read permissions)
+ * - KV_NAMESPACE: Analytics cache namespace
+ */
+
+import { Router, IRequest } from 'itty-router';
+
+// ============================================================================
+// Type Definitions
+// ============================================================================
+
+interface CloudflareMetrics {
+  r2_egress_gb: number;
+  d1_queries_count: number;
+  avg_db_latency_ms: number;
+  cache_hit_ratio_pct: number;
+}
+
+interface AnalyticsCache {
+  data: CloudflareMetrics;
+  timestamp: number;
+  ttl: number;
+}
+
+// ============================================================================
+// Environment & Router Setup
+// ============================================================================
+
+const router = Router();
+
+interface Env {
+  CF_ACCOUNT_ID: string;
+  CF_API_TOKEN: string;
+  ANALYTICS_CACHE: KVNamespace;
+}
+
+// ============================================================================
+// Utility Functions
+// ============================================================================
+
+/**
+ * Fetch R2 metrics from Cloudflare GraphQL API
+ */
+async function fetchR2Metrics(accountId: string, apiToken: string): Promise<{ egress_gb: number }> {
+  const query = `
+    query {
+      viewer {
+        accounts(filter: { accountTag: "${accountId}" }) {
+          r2 {
+            totalObjectCount
+            totalObjectSize
+            totalRequestsByType {
+              type
+              count
+            }
+            dailyEgress {
+              bytes
+              date
+            }
+          }
+        }
+      }
+    }
+  `;
+
+  try {
+    const response = await fetch('https://api.cloudflare.com/client/v4/graphql', {
+      method: 'POST',
+      headers: {
+        'Authorization': `Bearer ${apiToken}`,
+        'Content-Type': 'application/json',
+      },
+      body: JSON.stringify({ query }),
+    });
+
+    if (!response.ok) {
+      console.error('R2 metrics fetch failed:', response.status);
+      return { egress_gb: 0 };
+    }

+    const data = await response.json() as any;
+    const egressBytes = data?.data?.viewer?.accounts?.[0]?.r2?.dailyEgress?.[0]?.bytes || 0;
+    return { egress_gb: egressBytes / 1e9 };
+  } catch (error) {
+    console.error('R2 metrics error:', error);
+    return { egress_gb: 0 };
+  }
+}
+
+/**
+ * Fetch D1 metrics from Cloudflare API
+ */
+async function fetchD1Metrics(accountId: string, apiToken: string): Promise<{ queries_count: number; latency_ms: number }> {
+  try {
+    const response = await fetch(
+      `https://api.cloudflare.com/client/v4/accounts/${accountId}/d1/database`,
+      {
+        method: 'GET',
+        headers: {
+          'Authorization': `Bearer ${apiToken}`,
+          'Content-Type': 'application/json',
+        },
+      }
+    );

+    if (!response.ok) {
+      console.error('D1 metrics fetch failed:', response.status);
+      return { queries_count: 0, latency_ms: 0 };
+    }

+    const data = await response.json() as any;
+    // Parse D1 metrics from response (adjust based on actual API response structure)
+    const queriesCount = data?.result?.[0]?.query_count || 0;
+    const latencyMs = data?.result?.[0]?.avg_latency_ms || 0;
+
+    return { queries_count: queriesCount, latency_ms: latencyMs };
+  } catch (error) {
+    console.error('D1 metrics error:', error);
+    return { queries_count: 0, latency_ms: 0 };
+  }
+}
+
+/**
+ * Fetch Analytics Engine metrics
+ */
+async function fetchAnalyticsEngineMetrics(accountId: string, apiToken: string): Promise<{ cache_ratio_pct: number }> {
+  try {
+    const query = `
+      query {
+        viewer {
+          zones {
+            httpRequests1dGroups(limit: 1) {
+              sum {
+                cachedRequests
+                requests
+              }
+            }
+          }
+        }
+      }
+    `;
+
+    const response = await fetch('https://api.cloudflare.com/client/v4/graphql', {
+      method: 'POST',
+      headers: {
+        'Authorization': `Bearer ${apiToken}`,
+        'Content-Type': 'application/json',
+      },
+      body: JSON.stringify({ query }),
+    });

+    if (!response.ok) {
+      return { cache_ratio_pct: 0 };
+    }

+    const data = await response.json() as any;
+    const cached = data?.data?.viewer?.zones?.[0]?.httpRequests1dGroups?.[0]?.sum?.cachedRequests || 0;
+    const total = data?.data?.viewer?.zones?.[0]?.httpRequests1dGroups?.[0]?.sum?.requests || 1;
+
+    return { cache_ratio_pct: (cached / total) * 100 };
+  } catch (error) {
+    console.error('Analytics Engine metrics error:', error);
+    return { cache_ratio_pct: 0 };
+  }
+}
+
+/**
+ * Get cached metrics or fetch fresh ones
+ */
+async function getOrFetchMetrics(
+  env: Env,
+  bypassCache: boolean = false
+): Promise<CloudflareMetrics> {
+  const cacheKey = 'analytics:metrics:all';
+  const cacheTtl = 300; // 5 minutes
+
+  // Check cache if not bypassed
+  if (!bypassCache) {
+    const cached = await env.ANALYTICS_CACHE.get(cacheKey);
+    if (cached) {
+      try {
+        const data = JSON.parse(cached) as AnalyticsCache;
+        if (Date.now() - data.timestamp < data.ttl * 1000) {
+          return data.data;
+        }
+      } catch (e) {
+        console.error('Cache parse error:', e);
+      }
+    }
+  }

+  // Fetch fresh metrics in parallel
+  const [r2Metrics, d1Metrics, analyticsMetrics] = await Promise.all([
+    fetchR2Metrics(env.CF_ACCOUNT_ID, env.CF_API_TOKEN),
+    fetchD1Metrics(env.CF_ACCOUNT_ID, env.CF_API_TOKEN),
+    fetchAnalyticsEngineMetrics(env.CF_ACCOUNT_ID, env.CF_API_TOKEN),
+  ]);

+  const aggregated: CloudflareMetrics = {
+    r2_egress_gb: r2Metrics.egress_gb,
+    d1_queries_count: d1Metrics.queries_count,
+    avg_db_latency_ms: d1Metrics.latency_ms,
+    cache_hit_ratio_pct: analyticsMetrics.cache_ratio_pct,
+  };

+  // Cache result
+  try {
+    await env.ANALYTICS_CACHE.put(
+      cacheKey,
+      JSON.stringify({
+        data: aggregated,
+        timestamp: Date.now(),
+        ttl: cacheTtl,
+      }),
+      { expirationTtl: cacheTtl }
+    );
+  } catch (e) {
+    console.error('Cache write error:', e);
+  }

+  return aggregated;
+}
+
+// ============================================================================
+// Routes
+// ============================================================================
+
+/**
+ * GET /metrics
+ * Returns aggregated infrastructure metrics
+ */
+router.get('/metrics', async (request: IRequest, env: Env) => {
+  try {
+    const bypassCache = new URL(request.url).searchParams.get('cache_bypass') === 'true';
+    const metrics = await getOrFetchMetrics(env, bypassCache);
+
+    return new Response(JSON.stringify(metrics), {
+      status: 200,
+      headers: {
+        'Content-Type': 'application/json',
+        'Cache-Control': 'public, max-age=300',
+      },
+    });
+  } catch (error) {
+    console.error('Metrics endpoint error:', error);
+    return new Response(
+      JSON.stringify({ error: 'Failed to fetch metrics' }),
+      { status: 500, headers: { 'Content-Type': 'application/json' } }
+    );
+  }
+});
+
+/**
+ * Health check endpoint
+ */
+router.get('/health', () => {
+  return new Response(JSON.stringify({ status: 'ok' }), {
+    status: 200,
+    headers: { 'Content-Type': 'application/json' },
+  });
+});
+
+// ============================================================================
+// Export
+// ============================================================================
+
+export default {
+  fetch: router.handle,
+};
