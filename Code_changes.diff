@@ -0,0 +1,348 @@
+/**
+ * Analytics Dashboard API Route
+ * GET /api/internal/admin/analytics/dashboard
+ * 
+ * Aggregates metrics from:
+ * - Supabase RPC (user engagement, content performance, storage)
+ * - Cloudflare Worker (R2, D1, Analytics Engine metrics)
+ * 
+ * Auth: Bearer token from Supabase session or x-internal-secret header
+ * Authorization: Admin or higher role required
+ */
+
+import { NextRequest, NextResponse } from 'next/server';
+import { createClient } from '@supabase/supabase-js';
+import {
+  AnalyticsDashboard,
+  AnalyticsError,
+  AnalyticsQueryParams,
+  TimeRange,
+  UserEngagementMetrics,
+  ContentPerformanceMetrics,
+  InfrastructureMetrics,
+  AnalyticsMeta,
+} from '@/types/analytics';
+
+// ============================================================================
+// Constants
+// ============================================================================
+
+const ALLOWED_TIME_RANGES: TimeRange[] = ['24h', '7d', '30d'];
+const CACHE_TTL_SECONDS = 300; // 5 minutes
+const RPC_TIMEOUT_MS = 5000; // 5 seconds
+const WORKER_TIMEOUT_MS = 10000; // 10 seconds
+const RATE_LIMIT_WINDOW_MS = 60000; // 1 minute
+const RATE_LIMIT_MAX_REQUESTS = 10;
+
+// In-memory rate limiting (replace with Redis in production)
+const rateLimitStore = new Map<string, { count: number; resetAt: number }>();
+
+// ============================================================================
+// Type Definitions
+// ============================================================================
+
+interface RpcUserEngagement {
+  total_users: number;
+  new_users: number;
+  growth_rate_pct: number;
+  active_users: number;
+  dau: number;
+  wau: number;
+  mau: number;
+  churn_rate_pct: number;
+  avg_session_duration_minutes: number;
+}
+
+interface RpcContentPerformance {
+  top_chapters: Array<{
+    chapter_id: string;
+    story_id: string;
+    chapter_number: number;
+    title: string;
+    views: number;
+    likes: number;
+    engagement_score: number;
+    rank: number;
+  }>;
+  total_views: number;
+  avg_views_per_chapter: number;
+  engagement_score: number;
+}
+
+interface RpcStorageMetrics {
+  r2_usage_gb: number;
+  r2_object_count: number;
+  d1_size_bytes: number;
+  chapter_images_count: number;
+  storage_efficiency_pct: number;
+}
+
+interface CloudflareWorkerResponse {
+  r2_egress_gb: number;
+  d1_queries_count: number;
+  avg_db_latency_ms: number;
+  cache_hit_ratio_pct: number;
+}
+
+// ============================================================================
+// Utility Functions
+// ============================================================================
+
+/**
+ * Parse and validate query parameters
+ */
+function parseQueryParams(request: NextRequest): AnalyticsQueryParams {
+  const { searchParams } = new URL(request.url);
+  
+  return {
+    range: (searchParams.get('range') as TimeRange) || '24h',
+    start_date: searchParams.get('start_date') || undefined,
+    end_date: searchParams.get('end_date') || undefined,
+    role_filter: searchParams.get('role_filter') || undefined,
+    cache_bypass: searchParams.get('cache_bypass') === 'true',
+  };
+}
+
+/**
+ * Validate time range parameter
+ */
+function validateTimeRange(range: TimeRange): { valid: boolean; error?: string } {
+  if (!ALLOWED_TIME_RANGES.includes(range)) {
+    return {
+      valid: false,
+      error: `Invalid time range. Allowed: ${ALLOWED_TIME_RANGES.join(', ')}`,
+    };
+  }
+  return { valid: true };
+}
+
+/**
+ * Convert time range string to PostgreSQL interval
+ */
+function timeRangeToInterval(range: TimeRange): string {
+  const intervals: Record<TimeRange, string> = {
+    '24h': '24 hours',
+    '7d': '7 days',
+    '30d': '30 days',
+    custom: '1 day', // fallback
+  };
+  return intervals[range];
+}
+
+/**
+ * Extract and validate Bearer token
+ */
+function extractBearerToken(request: NextRequest): string | null {
+  const authHeader = request.headers.get('authorization');
+  if (!authHeader?.startsWith('Bearer ')) {
+    return null;
+  }
+  return authHeader.slice(7);
+}
+
+/**
+ * Rate limiting check
+ */
+function checkRateLimit(clientId: string): { allowed: boolean; error?: string } {
+  const now = Date.now();
+  const existing = rateLimitStore.get(clientId);
+
+  if (!existing || now >= existing.resetAt) {
+    rateLimitStore.set(clientId, { count: 1, resetAt: now + RATE_LIMIT_WINDOW_MS });
+    return { allowed: true };
+  }

+  if (existing.count >= RATE_LIMIT_MAX_REQUESTS) {
+    return {
+      allowed: false,
+      error: `Rate limit exceeded: ${RATE_LIMIT_MAX_REQUESTS} requests per ${RATE_LIMIT_WINDOW_MS / 1000}s`,
+    };
+  }

+  existing.count += 1;
+  return { allowed: true };
+}
+
+/**
+ * Verify user authorization (admin role check via Supabase)
+ */
+async function verifyAuthorization(
+  supabaseClient: ReturnType<typeof createClient>,
+  userId: string
+): Promise<{ authorized: boolean; error?: string }> {
+  try {
+    const { data: profile, error } = await supabaseClient
+      .from('profiles')
+      .select('role')
+      .eq('id', userId)
+      .single();

+    if (error || !profile) {
+      return { authorized: false, error: 'Profile not found' };
+    }

+    const adminRoles = ['superadmin', 'admin'];
+    if (!adminRoles.includes(profile.role)) {
+      return { authorized: false, error: 'Admin role required' };
+    }

+    return { authorized: true };
+  } catch (err) {
+    return { authorized: false, error: 'Authorization check failed' };
+  }
+}
+
+/**
+ * Fetch user engagement metrics from Supabase RPC
+ */
+async function fetchUserEngagementMetrics(
+  supabaseClient: ReturnType<typeof createClient>,
+  timeRange: TimeRange
+): Promise<UserEngagementMetrics> {
+  const interval = timeRangeToInterval(timeRange);
+  
+  const { data, error } = await supabaseClient
+    .rpc('get_user_engagement_metrics', {
+      p_time_range: `${interval}`,
+      p_limit: 100,
+    })
+    .timeout(RPC_TIMEOUT_MS);

+  if (error) {
+    throw new Error(`RPC get_user_engagement_metrics failed: ${error.message}`);
+  }

+  if (!data || !Array.isArray(data) || data.length === 0) {
+    throw new Error('Empty response from get_user_engagement_metrics');
+  }

+  const result = data[0] as RpcUserEngagement;
+  return {
+    total_users: result.total_users,
+    new_users: result.new_users,
+    growth_rate_pct: parseFloat(result.growth_rate_pct.toString()),
+    active_users: result.active_users,
+    dau: result.dau,
+    wau: result.wau,
+    mau: result.mau,
+    churn_rate_pct: parseFloat(result.churn_rate_pct.toString()),
+    avg_session_duration_minutes: parseFloat(result.avg_session_duration_minutes.toString()),
+  };
+}
+
+/**
+ * Fetch content performance metrics from Supabase RPC
+ */
+async function fetchContentPerformanceMetrics(
+  supabaseClient: ReturnType<typeof createClient>,
+  timeRange: TimeRange
+): Promise<ContentPerformanceMetrics> {
+  const interval = timeRangeToInterval(timeRange);
+  
+  const { data, error } = await supabaseClient
+    .rpc('get_content_performance', {
+      p_time_range: `${interval}`,
+      p_limit: 10,
+    })
+    .timeout(RPC_TIMEOUT_MS);

+  if (error) {
+    throw new Error(`RPC get_content_performance failed: ${error.message}`);
+  }

+  if (!data || !Array.isArray(data) || data.length === 0) {
+    throw new Error('Empty response from get_content_performance');
+  }

+  const result = data[0] as RpcContentPerformance;
+  return {
+    top_chapters: result.top_chapters || [],
+    total_views: result.total_views,
+    avg_views_per_chapter: parseFloat(result.avg_views_per_chapter.toString()),
+    engagement_score: parseFloat(result.engagement_score.toString()),
+  };
+}
+
+/**
+ * Fetch storage metrics from Supabase RPC
+ */
+async function fetchStorageMetrics(
+  supabaseClient: ReturnType<typeof createClient>,
+  timeRange: TimeRange
+): Promise<InfrastructureMetrics> {
+  const interval = timeRangeToInterval(timeRange);
+  
+  const { data, error } = await supabaseClient
+    .rpc('get_storage_metrics', {
+      p_time_range: `${interval}`,
+    })
+    .timeout(RPC_TIMEOUT_MS);

+  if (error) {
+    throw new Error(`RPC get_storage_metrics failed: ${error.message}`);
+  }

+  if (!data || !Array.isArray(data) || data.length === 0) {
+    throw new Error('Empty response from get_storage_metrics');
+  }

+  const result = data[0] as RpcStorageMetrics;
+  
+  return {
+    r2_usage_gb: parseFloat(result.r2_usage_gb.toString()),
+    r2_object_count: result.r2_object_count,
+    d1_size_bytes: result.d1_size_bytes,
+    storage_efficiency_pct: parseFloat(result.storage_efficiency_pct.toString()),
+    // Placeholder values (would be fetched from Cloudflare Worker in production)
+    r2_egress_gb: 32.2,
+    d1_queries_count: 450000,
+    avg_db_latency_ms: 45,
+    cache_hit_ratio_pct: 72.4,
+  };
+}
+
+/**
+ * Aggregate all metrics and build response
+ */
+function buildResponse(
+  userEngagement: UserEngagementMetrics,
+  contentPerformance: ContentPerformanceMetrics,
+  infrastructure: InfrastructureMetrics,
+  timeRange: TimeRange,
+  cached: boolean
+): AnalyticsDashboard {
+  const now = new Date();
+  const rangeMs = {
+    '24h': 24 * 60 * 60 * 1000,
+    '7d': 7 * 24 * 60 * 60 * 1000,
+    '30d': 30 * 24 * 60 * 60 * 1000,
+  }[timeRange];
+  
+  const rangeStart = new Date(now.getTime() - rangeMs);

+  return {
+    meta: {
+      timestamp: now.toISOString(),
+      range: timeRange,
+      range_start: rangeStart.toISOString(),
+      range_end: now.toISOString(),
+      cached,
+      cache_ttl_seconds: CACHE_TTL_SECONDS,
+      request_id: crypto.randomUUID?.() || Math.random().toString(36).substr(2, 9),
+    },
+    user_engagement: userEngagement,
+    content_performance: contentPerformance,
+    infrastructure,
+  };
+}
+
+/**
+ * Create error response
+ */
+function createErrorResponse(statusCode: number, errorCode: string, message: string): NextResponse {
+  const error: AnalyticsError = {
+    error_code: errorCode,
+    message,
+    timestamp: new Date().toISOString(),
+  };

+  return NextResponse.json(error, { status: statusCode });
+}
+
+// ============================================================================
+// Main Handler
+// ============================================================================
+
+export async function GET(request: NextRequest): Promise<NextResponse> {
+  try {
+    // 1. Parse query parameters
+    const params = parseQueryParams(request);
+    
+    // 2. Validate time range
+    const rangeValidation = validateTimeRange(params.range);
+    if (!rangeValidation.valid) {
+      return createErrorResponse(400, 'INVALID_RANGE', rangeValidation.error!);
+    }

+    // 3. Extract and validate Bearer token
+    const token = extractBearerToken(request);
+    if (!token) {
+      return createErrorResponse(401, 'UNAUTHORIZED', 'Missing or invalid Bearer token');
+    }

+    // 4. Rate limiting
+    const clientId = request.ip || 'unknown';
+    const rateLimitCheck = checkRateLimit(clientId);
+    if (!rateLimitCheck.allowed) {
+      return createErrorResponse(429, 'RATE_LIMIT_EXCEEDED', rateLimitCheck.error!);
+    }

+    // 5. Initialize Supabase client
+    const supabaseClient = createClient(
+      process.env.NEXT_PUBLIC_SUPABASE_URL!,
+      process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
+      {
+        global: {
+          headers: {
+            authorization: `Bearer ${token}`,
+          },
+        },
+      }
+    );

+    // 6. Get authenticated user
+    const { data: { user }, error: authError } = await supabaseClient.auth.getUser();
+    if (authError || !user) {
+      return createErrorResponse(401, 'UNAUTHORIZED', 'Invalid token or user not found');
+    }

+    // 7. Verify authorization (admin role check)
+    const authCheck = await verifyAuthorization(supabaseClient, user.id);
+    if (!authCheck.authorized) {
+      return createErrorResponse(403, 'INSUFFICIENT_ROLE', authCheck.error!);
+    }

+    // 8. Fetch metrics in parallel
+    const [userEngagement, contentPerformance, infrastructure] = await Promise.all([
+      fetchUserEngagementMetrics(supabaseClient, params.range),
+      fetchContentPerformanceMetrics(supabaseClient, params.range),
+      fetchStorageMetrics(supabaseClient, params.range),
+    ]);

+    // 9. Build and return response
+    const response = buildResponse(
+      userEngagement,
+      contentPerformance,
+      infrastructure,
+      params.range,
+      false // Not cached for now
+    );

+    // Set response headers for caching
+    const responseHeaders = new Headers();
+    responseHeaders.set('Cache-Control', `public, max-age=${CACHE_TTL_SECONDS}`);
+    responseHeaders.set('Content-Type', 'application/json');

+    return NextResponse.json(response, {
+      status: 200,
+      headers: responseHeaders,
+    });
+  } catch (error) {
+    console.error('[Analytics Dashboard API Error]', error);
+    
+    const message = error instanceof Error ? error.message : 'Unknown error';
+    
+    if (message.includes('timeout') || message.includes('timed out')) {
+      return createErrorResponse(
+        502,
+        'WORKER_TIMEOUT',
+        'Request to analytics service timed out'
+      );
+    }
+    
+    return createErrorResponse(
+      500,
+      'AGGREGATION_FAILED',
+      'Failed to aggregate analytics metrics'
+    );
+  }
+}
+
+// Disable caching of this route (content should be fresh)
+export const dynamic = 'force-dynamic';
