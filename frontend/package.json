{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "dev:clean": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true})\" && next dev -p 3001 -H 0.0.0.0",
    "dev:rescue": "node scripts/dev-rescue.mjs && next dev -p 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3001 -H 0.0.0.0",
    "preview": "next start -p 3001 -H 0.0.0.0",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test auth-boundary",
    "test:e2e:ui": "playwright test --ui",
    "ci:verify": "npm run lint && npm run build && npm run test:run",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "env:add-service-key": "node ./scripts/add_service_key.mjs",
    "env:use-emulator": "node ./scripts/use_emulator.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^1.52.0",
    "@light-story/api-types": "file:../packages/api-types",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.42.0",
    "next": "^15.3.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "10.4.0",
    "eslint-config-next": "16.2.6",
    "happy-dom": "^20.9.0",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.2.3",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
