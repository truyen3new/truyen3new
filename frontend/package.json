{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/import_root_env.mjs",
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "dev:clean": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true})\" && next dev -p 3001 -H 0.0.0.0",
    "dev:rescue": "node scripts/dev-rescue.mjs && next dev -p 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3001 -H 0.0.0.0",
    "preview": "next start -p 3001 -H 0.0.0.0",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "ci:verify": "npm run lint && npm run build && npm run test:run",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "test:internal-auth": "node ./tests/check_internal_routes.mjs",
    "env:add-service-key": "node ./scripts/add_service_key.mjs",
    "env:use-emulator": "node ./scripts/use_emulator.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.52.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-query": "^5.100.9",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.23.24",
    "next": "^16.2.4",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "10.3.0",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "supabase": "^2.98.2",
    "tailwindcss": "^4.2.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
