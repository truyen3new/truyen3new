# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_t_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_t_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 Storage - Image Uploads
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# R2 Bucket Names (for comic covers and chapters)
NEXT_PUBLIC_R2_BUCKET_COVERS=your-covers-bucket
NEXT_PUBLIC_R2_BUCKET_CHAPTERS=your-chapters-bucket

# Backend D1 Configuration (Optional - for multi-tenant backend)
CF_API_TOKEN=your-cloudflare-api-token-with-d1-permissions
ADMIN_API_KEY=your-secret-admin-api-key
BACKEND_D1_SAAS_URL=https://your-backend-d1-saas.example.com
BACKEND_D1_SAAS_ADMIN_KEY=your-backend-d1-saas-admin-key
